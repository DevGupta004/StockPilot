# Copy to .env and fill in. NEVER commit your real .env.

# --- News provider (default: marketaux) ---
# Free key (~100 req/day, covers India): https://www.marketaux.com/  -> Sign up -> Dashboard
MARKETAUX_API_KEY=

# --- Market data fallback (default provider is yfinance, no key needed) ---
# Free tier ~800 calls/day, ~4h delay, global incl. India: https://twelvedata.com/
TWELVEDATA_API_KEY=

# --- Provider selection (optional) ---
# MARKET_PROVIDER=yfinance      # or twelvedata
# NEWS_PROVIDER=marketaux       # or rss  (RSS needs no key; uses VADER locally)
# LIVE_PROVIDER=nsepython       # quasi-realtime NSE "Now" quote; or yfinance (delayed)

# --- Trading profile (applied to a bare "run my daily picks") ---
# Universe scanned when none is passed. A preset name ("under500"/"cheap"/"nifty"),
# an inline list "RELIANCE.NS,TCS.NS", or a single symbol.
# STOCK_UNIVERSE=under500
# Only suggest stocks at/under this price (₹). 0 or unset = no cap.
# MAX_PRICE=500
# Trading capital (₹) for position sizing.
# CAPITAL=150000
# Fraction of capital risked to the stop per trade (0.02 = 2%).
# RISK_PER_TRADE=0.02
# Confidence bar separating ACTIONABLE from LOW CONFIDENCE.
# MIN_CONFIDENCE=0.55

# --- Other tunables (optional; sane defaults in config.py) ---
# WEIGHT_TECHNICAL=0.60
# WEIGHT_SENTIMENT=0.40
# LOOKBACK_DAYS=270
# NEWS_LOOKBACK_HOURS=72
# How far back to scan FREE NSE corporate announcements for a catalyst (order win,
# board outcome, takeover/stake, fundraise). Recency-weighted, so wide is safe.
# CATALYST_LOOKBACK_HOURS=240
# VOLUME_SPIKE_MULT=1.5
# MIN_SURGE=2.0          # scan_volume_spikes: recent-vs-baseline volume multiple to qualify
# Volume lookback windows (trading days). VOLUME_BASE = "normal" baseline (~1 month);
# VOLUME_WINDOW = recent burst compared to it (match to your hold horizon — short for
# 1-2 day swings). DRY_VOLUME_RATIO = below this (last vol / baseline avg) = weak
# conviction → LONG score penalty.
# VOLUME_BASE=20
# VOLUME_WINDOW=7
# DRY_VOLUME_RATIO=0.6
# ATR_TARGET_MULT=1.5
# ATR_STOP_MULT=1.0
# Deepest pullback (in ATRs below spot) the buy level may ask for. EMA21 is often
# 5-8% below a trending stock (never fills in 1-2 days); this clamps to a reachable
# dip with a buy-at-open fallback. 0 = enter at market.
# MAX_PULLBACK_ATR=0.5
# In a RISK-OFF market (Nifty down-trend) LONG confidence is multiplied by this.
# RISK_OFF_FACTOR=0.85
# CACHE_DIR=.cache

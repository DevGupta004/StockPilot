# Local secrets + config — gitignored. Do not commit.

# --- Keys ---
MARKETAUX_API_KEY=TkCIcjmnBt5YcIdHdqownMttKIBpulYebcsHKjDp
# Market data fallback (no key needed for default yfinance)
TWELVEDATA_API_KEY=

# --- Provider selection (defaults shown) ---
# MARKET_PROVIDER=yfinance
# NEWS_PROVIDER=marketaux
# Live "Now" quote: nsepython (quasi-realtime NSE, default) or yfinance (delayed)
# LIVE_PROVIDER=nsepython

# --- Trading profile: delivery (CNC), ₹1.5 lakh, sub-₹500 stocks ---
# Universe scanned when you don't pass one. Fetched LIVE from NSE (cached per day):
# nifty50 | nifty100 | nifty200 | nifty500 | niftymidcap150 | niftysmallcap250 |
# niftynext50 | all. The MAX_PRICE filter below does the "sub-₹500" part.
STOCK_UNIVERSE=nifty500
# Only suggest stocks at/under this price (₹). 0 or unset = no cap.
MAX_PRICE=1000
# Trading capital (₹) used for position sizing.
CAPITAL=150000
# Fraction of capital risked to the stop per trade (0.02 = 2%).
RISK_PER_TRADE=0.02
# Confidence bar separating ACTIONABLE from LOW CONFIDENCE.
MIN_CONFIDENCE=0.55
# Delivery (CNC) mode: LONG-only picks (shorts can't be held as delivery on NSE).
DELIVERY_ONLY=true

# --- Score blend + indicators (optional) ---
# WEIGHT_TECHNICAL=0.60
# WEIGHT_SENTIMENT=0.40
# LOOKBACK_DAYS=270
# NEWS_LOOKBACK_HOURS=72
# FREE NSE corporate-announcement catalyst scan window (recency-weighted).
# CATALYST_LOOKBACK_HOURS=240
# VOLUME_SPIKE_MULT=1.5
MIN_SURGE=1.5          # scan_volume_spikes: recent-vs-baseline volume multiple to qualify
# Volume lookback windows (trading days). VOLUME_BASE = "normal" baseline (~1 month);
# VOLUME_WINDOW = recent burst vs it (match to hold horizon — short for 1-2 day swings).
# DRY_VOLUME_RATIO = below this (last vol / baseline avg) = weak conviction → LONG penalty.
# VOLUME_BASE=20
VOLUME_WINDOW=20
# DRY_VOLUME_RATIO=0.6
# ATR_TARGET_MULT=1.5
# ATR_STOP_MULT=1.0
# Buy-level + market-regime knobs (added with the accuracy upgrades):
# MAX_PULLBACK_ATR=0.5   # deepest dip the buy level may ask for (0 = enter at market)
# RISK_OFF_FACTOR=0.85   # LONG confidence ×this when Nifty is RISK-OFF
